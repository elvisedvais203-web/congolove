{
  "name": "kongo-love-platform",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:backend dev:frontend",
    "dev:backend": "npm --workspace @kongo-love/backend run dev",
    "dev:frontend": "npm --workspace @kongo-love/frontend run dev",
    "build": "npm-run-all build:shared build:backend build:frontend",
    "build:shared": "npm --workspace @kongo-love/shared run build",
    "build:backend": "npm --workspace @kongo-love/backend run build",
    "build:frontend": "npm --workspace @kongo-love/frontend run build",
    "lint": "npm-run-all lint:backend lint:frontend",
    "lint:backend": "npm --workspace @kongo-love/backend run lint",
    "lint:frontend": "npm --workspace @kongo-love/frontend run lint"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
