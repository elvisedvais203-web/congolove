{
  "name": "nextalk-platform",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:backend dev:frontend",
    "dev:backend": "npm --workspace @nextalk/backend run dev",
    "dev:frontend": "npm --workspace @nextalk/frontend run dev",
    "build": "npm-run-all build:shared build:backend build:frontend",
    "build:shared": "npm --workspace @nextalk/shared run build",
    "build:backend": "npm --workspace @nextalk/backend run build",
    "build:frontend": "npm --workspace @nextalk/frontend run build",
    "lint": "npm-run-all lint:backend lint:frontend",
    "lint:backend": "npm --workspace @nextalk/backend run lint",
    "lint:frontend": "npm --workspace @nextalk/frontend run lint",
    "git:watch-push": "node scripts/git-autopush.mjs"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
