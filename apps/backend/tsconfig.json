{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["src", "prisma/seed.ts"],
  "exclude": [
    "src/scripts/**/*.example.ts",
    "src/routes/nextalklivestream.routes.ts",
    "src/routes/nextalkvideocall.routes.ts",
    "src/services/nextalkagora.service.ts",
    "src/services/nextalklivestream.service.ts",
    "src/services/nextalkvideocall.service.ts",
    "src/sockets/nextalklive.socket.ts"
  ]
}
